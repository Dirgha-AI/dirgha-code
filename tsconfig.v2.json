{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["es2022"],
    "rootDir": "src_v2",
    "outDir": "dist_v2",
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": ["src_v2/**/*.ts", "src_v2/**/*.tsx"],
  "exclude": ["node_modules", "src_v2/**/__tests__/**/*", "src_v2/**/*.test.ts"]
}
