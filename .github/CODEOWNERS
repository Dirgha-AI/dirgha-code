# Dirgha Code — code owners
#
# GitHub uses this to auto-request reviews on PRs touching listed paths.
# Combined with branch protection's `require_code_owner_reviews=true`,
# the listed owner's review becomes MANDATORY for sensitive paths.
#
# Supply-chain safety:
#   - Release infrastructure changes ALWAYS go through Salik.
#   - Telemetry / auth / tool-registry / provider-routing changes too —
#     these are the paths an attacker would target to redirect the CLI
#     to a hostile endpoint or exfiltrate credentials.
#
# Order matters — later patterns override earlier ones for overlapping paths.

# Default owner for everything not matched below
*                                                  @salikshah

# Source — TypeScript (canonical lives in src_v2; legacy v1 is quarantined)
/src_v2/                                           @salikshah
/src_v2/tui/ink/App.tsx                            @salikshah
/src_v2/cli/main.ts                                @salikshah

# Release + signing infrastructure — never merge without owner review
/.github/workflows/                                @salikshah
/.github/dependabot.yml                            @salikshah
/.github/settings.yml                              @salikshah
/.github/CODEOWNERS                                @salikshah
/release-please-config.json                        @salikshah
/.release-please-manifest.json                     @salikshah
/scripts/apply-branch-protection.sh                @salikshah
/scripts/prepublish-guard.sh                       @salikshah
/scripts/verify-install.sh                         @salikshah

# Telemetry — privacy-sensitive
/src_v2/telemetry/                                 @salikshah
/docs/privacy/                                     @salikshah

# Auth + BYOK keystore — credentials surface
/src_v2/cli/subcommands/keys.ts                    @salikshah
/src_v2/cli/subcommands/login.ts                   @salikshah
/src_v2/cli/subcommands/logout.ts                  @salikshah
/src_v2/cli/subcommands/telemetry.ts               @salikshah
/src_v2/integrations/                              @salikshah

# Tools registry + skill loader — supply-chain attack surface
/src_v2/tools/registry.ts                          @salikshah
/src_v2/tools/index.ts                             @salikshah
/src_v2/skills/install-npm.ts                      @salikshah
/src_v2/skills/                                    @salikshah

# Provider routing + model catalogue — pinning prevents prompt-injection
# attacks that redirect users to a hostile LLM endpoint
/src_v2/providers/                                 @salikshah
/src_v2/intelligence/                              @salikshah

# Test infrastructure — owner reviews changes that could mask regressions
/scripts/qa-app/                                   @salikshah
/scripts/smoke-matrix.sh                           @salikshah
/tools/ux-scorer/                                  @salikshah

# Docs lower-barrier (drive-by typo fixes welcome) but owner FYI
/docs/                                             @salikshah
/README.md                                         @salikshah
/CONTRIBUTING.md                                   @salikshah
/CHANGELOG.md                                      @salikshah
