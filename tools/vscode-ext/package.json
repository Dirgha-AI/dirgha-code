{
  "name": "@dirgha/vscode-ext",
  "displayName": "Dirgha",
  "description": "Dirgha CLI integration for VS Code",
  "version": "0.1.0",
  "publisher": "dirgha",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:dirgha.askInline",
    "onCommand:dirgha.openTerminal"
  ],
  "contributes": {
    "commands": [
      {
        "command": "dirgha.askInline",
        "title": "Dirgha: Ask Inline"
      },
      {
        "command": "dirgha.openTerminal",
        "title": "Dirgha: Open Terminal"
      }
    ],
    "keybindings": [
      {
        "command": "dirgha.askInline",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
