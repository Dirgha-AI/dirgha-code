#!/bin/sh
# TypeScript gate for CLI — blocks AI-introduced type drift at commit time
# Install: cp scripts/hooks/pre-commit-tsc .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
CLI_CHANGED=$(git diff --cached --name-only | grep -c "^domains/10-computer/cli/src/" || true)
if [ "$CLI_CHANGED" -gt 0 ]; then
  echo "CLI files staged — running tsc --noEmit..."
  cd domains/10-computer/cli && npx tsc --noEmit
  if [ $? -ne 0 ]; then
    echo "Commit blocked: TypeScript errors. Fix with: cd domains/10-computer/cli && npx tsc --noEmit"
    exit 1
  fi
  echo "TypeScript: OK"
fi
exit 0
