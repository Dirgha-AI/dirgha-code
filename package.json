{
  "name": "@dirgha/code",
  "version": "1.5.1",
  "description": "A CLI coding agent built on four pillars: BYOK across 17 providers, persistent memory, parallel agents, and scanned skills.",
  "type": "module",
  "main": "./dist_v2/index.js",
  "types": "./dist_v2/index.d.ts",
  "bin": {
    "dirgha": "./dist_v2/cli/main.js"
  },
  "files": [
    "dist_v2/",
    "README.md",
    "LICENSE",
    "CREDITS.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.v2.json && cp src_v2/context/default-soul.md dist_v2/context/default-soul.md",
    "build:watch": "tsc -p tsconfig.v2.json --watch",
    "clean": "rm -rf ./dist_v2",
    "test:cli": "node scripts/qa-app/run-all.mjs",
    "test:cli:offline": "node scripts/qa-app/run-all.mjs --offline",
    "typecheck": "tsc -p tsconfig.v2.json --noEmit",
    "v2": "node dist_v2/cli/main.js"
  },
  "dependencies": {
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.3.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "coding-agent",
    "llm",
    "byok",
    "ai",
    "agent",
    "tool-calling",
    "openrouter",
    "anthropic",
    "openai"
  ],
  "homepage": "https://github.com/Dirgha-AI/dirgha-code",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dirgha-AI/dirgha-code.git"
  },
  "bugs": {
    "url": "https://github.com/Dirgha-AI/dirgha-code/issues"
  },
  "author": "Dirgha AI Team",
  "license": "SEE LICENSE IN LICENSE"
}
