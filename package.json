{
  "name": "@dirgha/cli",
  "version": "1.4.0",
  "description": "Dirgha AI CLI - Intelligent command-line agent with multi-model support",
  "type": "module",
  "main": "./dist_v2/index.js",
  "types": "./dist_v2/index.d.ts",
  "bin": {
    "dirgha": "./dist_v2/cli/main.js",
    "dirgha-v1": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "build:v2": "tsc -p tsconfig.v2.json && cp src_v2/context/default-soul.md dist_v2/context/default-soul.md",
    "build:v2:watch": "tsc -p tsconfig.v2.json --watch",
    "clean": "rm -rf ./dist ./dist_v2",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:v2": "vitest run --dir src_v2",
    "test:cli": "node scripts/qa-app/run-all.mjs",
    "test:cli:quick": "node scripts/qa-app/run-all.mjs --quick",
    "test:cli:offline": "node scripts/qa-app/run-all.mjs --offline",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "typecheck:v2": "tsc -p tsconfig.v2.json --noEmit",
    "v2": "node dist_v2/cli/main.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/google": "^0.0.48",
    "@ai-sdk/openai": "^0.0.66",
    "@anthropic-ai/sdk": "^0.24.0",
    "@dirgha/pricing": "workspace:*",
    "ai": "^3.0.0",
    "better-sqlite3": "^11.3.0",
    "chalk": "^5.3.0",
    "cli-markdown": "^1.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "figlet": "^1.7.0",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "playwright": "^1.47.0",
    "react": "^18.3.0",
    "readline": "^1.3.0",
    "uuid": "^9.0.1",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "cli",
    "agent",
    "llm",
    "tool-calling"
  ],
  "author": "Dirgha AI Team",
  "license": "MIT"
}
