{
  "name": "@dirgha/code",
  "version": "1.20.1",
  "description": "CLI coding agent for complex agentic workflows and long-horizon development. Local models (llama.cpp / Ollama), BYOK across 17 providers, parallel agents, persistent memory, scanned skills.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dirgha": "./dist/cli/main.js"
  },
  "files": [
    "dist/",
    "scaffold-templates/",
    "README.md",
    "LICENSE",
    "CREDITS.md",
    "CHANGELOG.md",
    "vendor/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "build:watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf ./dist",
    "test": "vitest run --dir src",
    "test:cli": "node scripts/qa-app/run-all.mjs",
    "test:cli:offline": "node scripts/qa-app/run-all.mjs --offline",
    "test:tui": "bash scripts/qa-app/picker-flow.sh",
    "test:smoke": "bash scripts/smoke-matrix.sh all",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify-install": "bash scripts/verify-install.sh",
    "prepublish-guard": "bash scripts/prepublish-guard.sh",
    "prepublishOnly": "npm run prepublish-guard && npm run build && npm run verify-install",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix --max-warnings 0",
    "license-check": "license-checker --production --excludePackages 'argparse@1.0.10' --failOn 'GPL;AGPL;LGPL'",
    "gate": "bash scripts/gate.sh",
    "changelog:update": "node scripts/changelog-bump.mjs"
  },
  "dependencies": {
    "ink": "5.0.0",
    "ink-text-input": "6.0.0",
    "react": "^18.3.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "12.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "20.11.5",
    "@types/react": "18.3.0",
    "eslint": "9.39.4",
    "license-checker": "25.0.1",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.59.1",
    "vitest": "3.2.4"
  },
  "overrides": {
    "vite": ">=6.4.2",
    "esbuild": ">=0.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "coding-agent",
    "llm",
    "byok",
    "ai",
    "agent",
    "tool-calling",
    "openrouter",
    "anthropic",
    "openai"
  ],
  "homepage": "https://github.com/Dirgha-AI/dirgha-code",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dirgha-AI/dirgha-code.git"
  },
  "bugs": {
    "url": "https://github.com/Dirgha-AI/dirgha-code/issues"
  },
  "author": "Dirgha AI Team",
  "license": "SEE LICENSE IN LICENSE"
}
