  },
  "scripts": {
    "build": "node build.mjs",
    "build:dev": "node build.mjs --dev",
    "build:analyze": "node build.mjs --analyze",
    "dev": "tsx --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "node build.mjs"
  },
  "files": [
